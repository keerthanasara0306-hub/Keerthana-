<!DOCTYPE html>
<html>
<head>
    <title>FAQ Page</title>

    <style>
        body {
            background: #111;
            color: white;
            font-family: Arial;
            padding: 20px;
        }

        .faq {
            max-width: 500px;
            margin: auto;
        }

        .question {
            background: #1c1c1c;
            padding: 10px;
            margin-top: 10px;
            cursor: pointer;
            border-radius: 5px;
        }

        .answer {
            display: none;
            padding: 10px;
            background: #333;
            border-radius: 5px;
        }
    </style>
</head>

<body>

<h2 style="text-align:center;">FAQ Section</h2>

<div class="faq">

    <div class="question" onclick="toggle(this)">
        What is HTML?
    </div>
    <div class="answer">
        HTML is used to create web page structure.
    </div>

    <div class="question" onclick="toggle(this)">
        What is CSS?
    </div>
    <div class="answer">
        CSS is used to style web pages.
    </div>

    <div class="question" onclick="toggle(this)">
        What is JavaScript?
    </div>
    <div class="answer">
        JavaScript is used to add interactivity.
    </div>

</div>

<script>
function toggle(element) {
    let answer = element.nextElementSibling;

    if (answer.style.display === "block") {
        answer.style.display = "none";
    } else {
        answer.style.display = "block";
    }
}
</script>

</body>
</html>
