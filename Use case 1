<!DOCTYPE html>
<html>
<head>
<title>Multi Section Website</title>

<style>
body{
font-family: Arial;
margin:0;
background:#f4f4f4;
}

/* Navigation Bar */
nav{
background:#333;
padding:10px;
text-align:center;
}

nav a{
color:white;
margin:15px;
text-decoration:none;
font-size:18px;
}

/* Sections */
section{
padding:40px;
text-align:center;
}

#home{
background:#e3f2fd;
}

#about{
background:#fff3cd;
}

#contact{
background:#d4edda;
}

/* Button */
button{
padding:10px 20px;
background:blue;
color:white;
border:none;
cursor:pointer;
}
</style>

</head>

<body>

<!-- Navigation -->
<nav>
<a href="#home">Home</a>
<a href="#about">About</a>
<a href="#contact">Contact</a>
</nav>

<!-- Home Section -->
<section id="home">
<h1>Welcome to My Website</h1>
<p>This is the home section of the webpage.</p>
<button onclick="showMessage()">Click Me</button>
</section>

<!-- About Section -->
<section id="about">
<h1>About Us</h1>
<p>This section contains information about the project or organization.</p>
</section>

<!-- Contact Section -->
<section id="contact">
<h1>Contact</h1>
<p>Email: keerthanasara0306@gmail.com</p>
</section>

<script>
function showMessage(){
alert("Hello! Welcome to the Multi Section Website");
}
</script>

</body>
</html>
