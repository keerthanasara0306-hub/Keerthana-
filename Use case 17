<!DOCTYPE html>
<html>
<head>
    <title>Dashboard with Charts</title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            font-family: Arial;
            background: #111;
            color: white;
            text-align: center;
        }

        .container {
            width: 400px;
            margin: auto;
            margin-top: 50px;
            background: #1c1c1c;
            padding: 20px;
            border-radius: 10px;
        }
    </style>
</head>

<body>

<h2>Dashboard with Chart</h2>

<div class="container">
    <canvas id="myChart"></canvas>
</div>

<script>
let ctx = document.getElementById("myChart");

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr'],
        datasets: [{
            label: 'Sales Data',
            data: [10, 20, 15, 25],
            backgroundColor: ['red','blue','green','orange']
        }]
    }
});
</script>

</body>
</html>
