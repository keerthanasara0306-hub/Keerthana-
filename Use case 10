<!DOCTYPE html>
<html>
<head>
    <title>Chat UI</title>
    <style>
        body {
            background: #111;
            color: white;
            font-family: Arial;
            display: flex;
            justify-content: center;
            margin-top: 50px;
        }

        .chat-container {
            width: 300px;
            background: #1c1c1c;
            border-radius: 10px;
        }

        .chat-box {
            height: 300px;
            overflow-y: auto;
            padding: 10px;
        }

        .message {
            background: #333;
            padding: 8px;
            margin: 5px;
            border-radius: 5px;
        }

        .user {
            background: blue;
            text-align: right;
        }

        input {
            width: 70%;
            padding: 10px;
        }

        button {
            padding: 10px;
            background: green;
            color: white;
            border: none;
        }
    </style>
</head>

<body>

<div class="chat-container">
    <div id="chatBox" class="chat-box"></div>

    <input type="text" id="msg">
    <button onclick="send()">Send</button>
</div>

<script>
function send() {
    let input = document.getElementById("msg");

    if(input.value === ""){
        alert("Enter message");
        return;
    }

    let chat = document.getElementById("chatBox");

    let userMsg = document.createElement("div");
    userMsg.className = "message user";
    userMsg.innerText = input.value;

    chat.appendChild(userMsg);

    let text = input.value;
    input.value = "";

    setTimeout(()=>{
        let reply = document.createElement("div");
        reply.className = "message";
        reply.innerText = "Reply: " + text;

        chat.appendChild(reply);
    },1000);
}
</script>

</body>
</html>
