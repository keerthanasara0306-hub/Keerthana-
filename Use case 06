<!DOCTYPE html>
<html>

<head>
<title>Responsive Product Grid</title>

<style>

body{
font-family: Arial;
background-color:#f2f2f2;
text-align:center;
}

h1{
margin-top:20px;
}

.container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
padding:20px;
}

.product{
background:white;
padding:15px;
border-radius:10px;
box-shadow:0 0 5px gray;
}

.product img{
width:100%;
height:150px;
object-fit:cover;
}

.price{
color:green;
font-weight:bold;
}

</style>

</head>

<body>

<h1>Product Catalog</h1>

<div class="container">

<div class="product">
<img src="https://via.placeholder.com/200">
<h3>Product 1</h3>
<p class="price">₹500</p>
</div>

<div class="product">
<img src="https://via.placeholder.com/200">
<h3>Product 2</h3>
<p class="price">₹750</p>
</div>

<div class="product">
<img src="https://via.placeholder.com/200">
<h3>Product 3</h3>
<p class="price">₹900</p>
</div>

<div class="product">
<img src="https://via.placeholder.com/200">
<h3>Product 4</h3>
<p class="price">₹650</p>
</div>

</div>

</body>

</html>
