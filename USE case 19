<!DOCTYPE html>
<html>
<head>
    <title>REST API Integration</title>

    <style>
        body {
            font-family: Arial;
            background: #111;
            color: white;
            text-align: center;
        }

        .container {
            margin-top: 50px;
        }

        button {
            padding: 10px;
            background: blue;
            color: white;
            border: none;
            cursor: pointer;
        }

        .data {
            margin-top: 20px;
            background: #1c1c1c;
            padding: 15px;
            border-radius: 10px;
            display: inline-block;
        }
    </style>
</head>

<body>

<h2>REST API Data Integration</h2>

<div class="container">
    <button onclick="getData()">Fetch Data</button>

    <div id="result" class="data"></div>
</div>

<script>
function getData() {
    fetch("https://jsonplaceholder.typicode.com/users/1")
    .then(response => response.json())
    .then(data => {
        document.getElementById("result").innerHTML =
        "Name: " + data.name + "<br>" +
        "Email: " + data.email + "<br>" +
        "City: " + data.address.city;
    });
}
</script>

</body>
</html>
